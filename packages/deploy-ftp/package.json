{
  "name": "@mietextools/deploy-ftp",
  "version": "0.1.3",
  "description": "CLI tool for deploying files to an FTP server with zero-downtime rotation",
  "type": "module",
  "bin": {
    "deploy-ftp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "dependencies": {
    "basic-ftp": "^5.0.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
